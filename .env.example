# ETF Analyzer 环境配置模板
# 复制此文件为 .env 并填入真实值

# ==================== 运行环境 ====================
# 可选值: development, production
ETF_ENV=development

# ==================== 数据库配置 ====================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=etf_analyzer
DB_USER=root
DB_PASSWORD=

# ==================== Redis 配置 ====================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== Celery 配置 ====================
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# ==================== API 服务配置 ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ==================== 数据源配置 ====================
TUSHARE_TOKEN=
DATASOURCE_PRIORITY=akshare,tushare,baostock,pytdx
DATASOURCE_HEALTH_CHECK_INTERVAL=300
DATASOURCE_FAILURE_THRESHOLD=3
DATASOURCE_QUALITY_THRESHOLD=60
DATASOURCE_CROSS_VALIDATION_THRESHOLD=1.0
PYTDX_HOST=119.147.212.81
PYTDX_PORT=7709
