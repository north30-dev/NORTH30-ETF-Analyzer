# ETF Analyzer 环境配置模板
# 复制此文件为 .env 并填入真实值

# 运行环境: dev / test / prod
ETF_ENV=dev

# Tushare 数据源配置
TUSHARE_TOKEN=

# 通达信(pytdx)数据源配置
PYTDX_HOST=119.147.212.81
PYTDX_PORT=7709

# 数据源优先级（逗号分隔，可选值: akshare, tushare, baostock, pytdx）
DATASOURCE_PRIORITY=akshare,tushare,baostock,pytdx

# 数据源健康检查间隔（秒）
DATASOURCE_HEALTH_CHECK_INTERVAL=300

# 数据源连续失败告警阈值
DATASOURCE_FAILURE_THRESHOLD=3

# 数据质量评分告警阈值
DATA_QUALITY_THRESHOLD=60

# 交叉验证差异阈值（百分比）
CROSS_VALIDATION_THRESHOLD=1.0
